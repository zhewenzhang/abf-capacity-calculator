rules_version = '2';

// =====================================================================
// ABF Capacity Calculator — Firestore Security Rules (v1.18.0)
//
// Data model:
//   users/{uid}/projects/{projectId}/...       — personal data (private)
//   workspaces/{wid}                            — shared workspace doc
//   workspaces/{wid}/projects/{projectId}/...   — shared business data
//   userWorkspaces/{uid}/workspaces/{wid}       — per-user index entry
//
// Roles inside a workspace.members map: 'owner' | 'editor' | 'viewer'.
// - owner   → can read, write business data, manage members
// - editor  → can read + write business data, cannot manage members
// - viewer  → read-only on business data
// =====================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // ---------- Helpers ----------
    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function workspaceData(workspaceId) {
      return get(/databases/$(database)/documents/workspaces/$(workspaceId)).data;
    }

    function workspaceMembers(workspaceId) {
      return workspaceData(workspaceId).members;
    }

    function isMember(workspaceId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/workspaces/$(workspaceId))
        && request.auth.uid in workspaceMembers(workspaceId);
    }

    function memberRole(workspaceId) {
      return workspaceMembers(workspaceId)[request.auth.uid];
    }

    function isOwner(workspaceId) {
      return isMember(workspaceId) && memberRole(workspaceId) == 'owner';
    }

    function canWriteBusiness(workspaceId) {
      return isMember(workspaceId)
        && (memberRole(workspaceId) == 'owner' || memberRole(workspaceId) == 'editor');
    }

    // ---------- Personal data (legacy + v1.18 backward compat) ----------
    // users/{uid}/** is private to the user — same as before v1.18.
    match /users/{uid}/{document=**} {
      allow read, write: if isSelf(uid);
    }

    // ---------- Workspace root doc ----------
    match /workspaces/{workspaceId} {
      // Anyone in members can read the workspace doc itself.
      allow read: if isMember(workspaceId);

      // Create: caller must be the named owner AND seed members[uid] = 'owner'.
      allow create: if isSignedIn()
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.members[request.auth.uid] == 'owner';

      // Update: only the workspace owner may change membership / metadata.
      allow update: if isOwner(workspaceId)
        // Ownership cannot be silently transferred via update — keep owner stable.
        && request.resource.data.ownerId == resource.data.ownerId
        && request.resource.data.members[resource.data.ownerId] == 'owner';

      // Delete: only the owner.
      allow delete: if isOwner(workspaceId);
    }

    // ---------- Workspace business data ----------
    // Projects + nested collections (skus, forecasts, capacityPlans,
    // parameters, capacityVersions, skuVersions).
    match /workspaces/{workspaceId}/projects/{projectId}/{document=**} {
      allow read: if isMember(workspaceId);
      allow write: if canWriteBusiness(workspaceId);
    }

    // ---------- Per-user workspace index ----------
    // userWorkspaces/{uid}/workspaces/{wid} mirrors a member's role so the
    // client can list a user's workspaces without scanning every workspace.
    match /userWorkspaces/{uid}/workspaces/{workspaceId} {
      // The owning user can always read their own index.
      allow read: if isSelf(uid);

      // Writes:
      //   - The user themselves may seed/refresh their own entry IF they
      //     are already a member of the target workspace (cleanup / repair).
      //   - The workspace owner may write any member's index entry
      //     (this is how invites land — owners write to invitee's index).
      allow create, update: if isSignedIn() && (
        (isSelf(uid) && isMember(workspaceId))
        || isOwner(workspaceId)
      );

      // Delete:
      //   - The user can remove themselves.
      //   - The workspace owner can remove any member's index entry.
      allow delete: if isSignedIn() && (isSelf(uid) || isOwner(workspaceId));
    }
  }
}

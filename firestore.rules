rules_version = '2';

// =====================================================================
// ABF Capacity Calculator — Firestore Security Rules (v1.22.1)
//
// v1.22.1 hardening:
// - Snapshots are now immutable (no update allowed).
// - Personal snapshots: only the user can read/create/delete.
// - Workspace snapshots:
//   - Members can read.
//   - Owner/Editor can create (createdBy must equal auth.uid).
//   - Owner can delete any snapshot.
//   - Editor can only delete their own snapshots (createdBy == auth.uid).
//   - Viewer cannot create or delete.
// =====================================================================
//
// Data model:
//   users/{uid}/projects/{projectId}/...       — personal data (private)
//   workspaces/{wid}                            — shared workspace doc
//   workspaces/{wid}/projects/{projectId}/...   — shared business data
//   userWorkspaces/{uid}/workspaces/{wid}       — per-user index entry
//
// Roles inside a workspace.members map: 'owner' | 'editor' | 'viewer'.
// - owner   → can read, write business data, manage members
// - editor  → can read + write business data, cannot manage members
// - viewer  → read-only on business data
//
// v1.18.1 hardening:
// - Workspace creation is now a sequential client-side write
//   (workspace doc first, then index entry). The two-write split exists
//   because the index-entry rule needs `get(workspaces/{wid})` to see a
//   committed doc; a single batch would deny because same-batch writes
//   are NOT visible to get()/exists() during rule evaluation.
// - Initial owner index entry has its own narrow allow path keyed on
//   `get(workspaces/{wid}).ownerId == auth.uid`. No membership chicken-
//   and-egg.
// - Self-written index entries (by the same UID) cannot escalate role —
//   the written role must match the workspace's members[uid] value.
// - Owner update cannot drop or transfer ownership.
// =====================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // ---------- Helpers ----------
    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function workspaceExists(workspaceId) {
      return exists(/databases/$(database)/documents/workspaces/$(workspaceId));
    }

    function workspaceData(workspaceId) {
      return get(/databases/$(database)/documents/workspaces/$(workspaceId)).data;
    }

    function workspaceMembers(workspaceId) {
      return workspaceData(workspaceId).members;
    }

    function isMember(workspaceId) {
      return isSignedIn()
        && workspaceExists(workspaceId)
        && request.auth.uid in workspaceMembers(workspaceId);
    }

    function memberRole(workspaceId) {
      return workspaceMembers(workspaceId)[request.auth.uid];
    }

    function isOwner(workspaceId) {
      return isMember(workspaceId) && memberRole(workspaceId) == 'owner';
    }

    function canWriteBusiness(workspaceId) {
      return isMember(workspaceId)
        && (memberRole(workspaceId) == 'owner' || memberRole(workspaceId) == 'editor');
    }

    function isWorkspaceOwnerByDoc(workspaceId) {
      // Strict check that does NOT depend on members map presence; reads ownerId
      // directly. Used by the owner-bootstrap allow path for the index entry.
      return isSignedIn()
        && workspaceExists(workspaceId)
        && workspaceData(workspaceId).ownerId == request.auth.uid;
    }

    // ---------- Personal data (legacy + v1.18 backward compat) ----------
    // users/{uid}/** is private to the user — same as before v1.18.
    match /users/{uid}/{document=**} {
      allow read, write: if isSelf(uid);
    }

    // ---------- Workspace root doc ----------
    match /workspaces/{workspaceId} {
      // Anyone in members can read the workspace doc itself.
      allow read: if isMember(workspaceId);

      // Create: caller must be the named owner AND seed members[uid] = 'owner'.
      // Nothing depends on the doc itself yet, so no get()/exists() races.
      allow create: if isSignedIn()
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.members[request.auth.uid] == 'owner';

      // Update: only the workspace owner may change membership / metadata.
      // Ownership cannot be silently transferred or revoked via update.
      allow update: if isOwner(workspaceId)
        && request.resource.data.ownerId == resource.data.ownerId
        && request.resource.data.members[resource.data.ownerId] == 'owner';

      // Delete: only the owner.
      allow delete: if isOwner(workspaceId);
    }

    // ---------- Workspace business data ----------
    // Projects + nested collections (skus, forecasts, capacityPlans,
    // parameters, capacityVersions, skuVersions).
    // NOTE: Snapshots have their own dedicated rules below.
    match /workspaces/{workspaceId}/projects/{projectId}/{document=**} {
      allow read: if isMember(workspaceId);
      allow write: if canWriteBusiness(workspaceId);
    }

    // ---------- Personal snapshots (immutable) ----------
    // users/{uid}/projects/{projectId}/snapshots/{snapshotId}
    // - Only the user can read/create/delete.
    // - Update is forbidden (immutable).
    // - Create requires createdBy == auth.uid.
    match /users/{uid}/projects/{projectId}/snapshots/{snapshotId} {
      allow read: if isSelf(uid);
      allow create: if isSelf(uid)
        && request.resource.data.createdBy == request.auth.uid;
      allow delete: if isSelf(uid);
      // Update forbidden — snapshots are immutable
      allow update: if false;
    }

    // ---------- Workspace snapshots (immutable) ----------
    // workspaces/{workspaceId}/projects/{projectId}/snapshots/{snapshotId}
    // - Members can read.
    // - Owner/Editor can create (createdBy must equal auth.uid).
    // - Owner can delete any snapshot.
    // - Editor can only delete their own (createdBy == auth.uid).
    // - Viewer cannot create or delete.
    // - Update is forbidden (immutable).
    match /workspaces/{workspaceId}/projects/{projectId}/snapshots/{snapshotId} {
      // Read: all workspace members
      allow read: if isMember(workspaceId);

      // Create: owner or editor, createdBy must be auth.uid
      allow create: if isMember(workspaceId)
        && (memberRole(workspaceId) == 'owner' || memberRole(workspaceId) == 'editor')
        && request.resource.data.createdBy == request.auth.uid;

      // Delete: owner (any) or editor (own snapshots only)
      allow delete: if isMember(workspaceId) && (
        memberRole(workspaceId) == 'owner'
        || (memberRole(workspaceId) == 'editor' && resource.data.createdBy == request.auth.uid)
      );

      // Update forbidden — snapshots are immutable
      allow update: if false;
    }

    // ---------- Per-user workspace index ----------
    // userWorkspaces/{uid}/workspaces/{wid} mirrors a member's role so the
    // client can list a user's workspaces without scanning every workspace.
    //
    // Allow paths (most-specific first):
    //   1. Initial owner bootstrap — the second half of createWorkspace().
    //      The caller is the owner per the freshly-committed workspace doc.
    //      Role MUST be 'owner'.
    //   2. Owner inviting a member — the workspace owner writes an index
    //      entry for someone else. Role MUST match members[invitee].
    //   3. Self-repair — a member rewrites their own entry; role MUST
    //      match what the workspace says it should be (no escalation).
    match /userWorkspaces/{uid}/workspaces/{workspaceId} {
      // The owning user can always read their own index.
      allow read: if isSelf(uid);

      // Create:
      //   - Owner bootstrap: caller IS the workspace owner-by-doc, writing
      //     their own index entry as role=owner. This succeeds even when
      //     the workspace doc was just committed in the previous step (no
      //     `get` against the members map — only ownerId).
      //   - Owner-inviting-member: a non-self target whose role on the
      //     written index entry equals the workspace members[target].
      //   - Member self-repair: caller writes their own entry where the
      //     written role equals members[caller]; cannot escalate.
      allow create: if isSignedIn() && (
        // (1) owner bootstrap
        (
          isSelf(uid)
          && isWorkspaceOwnerByDoc(workspaceId)
          && request.resource.data.role == 'owner'
          && request.resource.data.ownerId == request.auth.uid
          && request.resource.data.workspaceId == workspaceId
        )
        // (2) owner inviting member
        || (
          isOwner(workspaceId)
          && !isSelf(uid)
          && request.resource.data.role == workspaceMembers(workspaceId)[uid]
          && request.resource.data.workspaceId == workspaceId
          && request.resource.data.ownerId == workspaceData(workspaceId).ownerId
        )
        // (3) member self-repair
        || (
          isSelf(uid)
          && isMember(workspaceId)
          && request.resource.data.role == memberRole(workspaceId)
          && request.resource.data.workspaceId == workspaceId
        )
      );

      // Update: same shape as create. Same caller, same role-constancy rules.
      allow update: if isSignedIn() && (
        // owner refreshing their own index
        (
          isSelf(uid)
          && isWorkspaceOwnerByDoc(workspaceId)
          && request.resource.data.role == 'owner'
        )
        // owner changing an invitee's role (updateWorkspaceMemberRole)
        || (
          isOwner(workspaceId)
          && !isSelf(uid)
          && request.resource.data.role == workspaceMembers(workspaceId)[uid]
        )
        // member refreshing their own entry (no role escalation)
        || (
          isSelf(uid)
          && isMember(workspaceId)
          && request.resource.data.role == memberRole(workspaceId)
        )
      );

      // Delete:
      //   - The user can remove themselves.
      //   - The workspace owner can remove any member's index entry
      //     (used when removeWorkspaceMember runs).
      allow delete: if isSignedIn() && (isSelf(uid) || isOwner(workspaceId));
    }
  }
}
